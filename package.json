{
  "name": "hex-viewer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --watch=false",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check '**/*.{js,jsx,mjs,json,css,html,md,yml,yaml}'",
    "format:fix": "prettier --write '**/*.{js,jsx,mjs,json,css,html,md,yml,yaml}'",
    "check": "npm run format && npm run lint && npm run coverage && npm run build",
    "deploy": "npm run build && gh-pages -d dist",
    "locales:generate": "node scripts/generate-locales.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "vite": "^6.3.4",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://doctorlai.github.io/hex-viewer"
}
